{% extends "../layouts/base.twig" %}
{% block style %}
	<link rel="stylesheet" href="/assets/css/home.css">
	<link rel="stylesheet" href="/assets/css/fleet.css">
{% endblock %}
{% block title %}
	<title>{{title}}</title>
{% endblock %}
{% block main %}
	<div class="page">
		{% include "../partials/sidebar.twig" %}

		<main>
			{% include "../partials/searchbar.twig" %}

			<!-- Bouton pour ajouter une nouvelle voiture -->
			<div class="add-car-btn">
				<button id="toggle-add-form">➕ Ajouter une voiture</button>
			</div>

			<!-- Formulaire rétractable pour ajouter une voiture -->
			<form id="car-add-form" action="/fleet/add" method="post">
				<div class="form-group">
					<label for="registration">Immatriculation</label>
					<input type="text" name="registration" id="registration" required>
				</div>
				<div class="form-group">
					<label for="carModel">Modèle</label>
					<input type="text" name="carModel" id="carModel" required>
				</div>
				<div class="form-group">
					<label for="transmission">Transmission</label>
					<select name="transmission" id="transmission">
						<option value="MANUELLE">Manuelle</option>
						<option value="AUTOMATIQUE">Automatique</option>
					</select>
				</div>
				<div class="form-group">
					<label for="employeeId">Employé (optionnel)</label>
					<select name="employeeId" id="employeeId">
						<option value="">--Non attribué--</option>
						{% for emp in employees %}
							{% set alreadyAssigned = false %}
							{% for carAssigned in cars %}
								{% if carAssigned.employeeId == emp.id %}
									{% set alreadyAssigned = true %}
								{% endif %}
							{% endfor %}
							{% if not alreadyAssigned %}
								<option value="{{ emp.id }}">{{ emp.firstName }}
									{{ emp.lastName | upper }}</option>
							{% endif %}
						{% endfor %}
					</select>
				</div>
				<button type="submit" class="submit-btn">Ajouter</button>
			</form>

			<!-- voitures -->
			<div class="cars-container">
				{% if cars.length > 0 %}
					{% for car in cars %}
						<div class="car-card" data-assigned="{{ car.employee ? 'true' : 'false' }}">

							<div class="car-info">
								<div class="car-plate">
									<img class="plate-flag" src="/assets/img/plaque-left.png" alt="France">
									<span class="plate-number">{{ car.registration }}</span>
									<img class="plate-dept" src="/assets/img/plaque-right.png" alt="83">
								</div>
								<h3>{{ car.carModel }}</h3>
								<p>
									<strong>Transmission:</strong>
									{{ car.transmission }}</p>
								<p>
									<strong>Employé:</strong>
									{{ car.employee ? car.employee.firstName ~ ' ' ~ car.employee.lastName | upper : 'Non attribué' }}
								</p>
							</div>

							<div class="car-actions">
								<button class="edit-btn" data-id="{{ car.id }}">✏ Modifier</button>
								<form action="/fleet/delete/{{ car.id }}" method="POST">
									<button type="submit" class="delete-btn">🗑 Supprimer</button>
								</form>
							</div>

							<!-- Formulaire de modification caché -->
							<form class="car-edit-form" id="edit-form-{{ car.id }}" action="/fleet/edit/{{ car.id }}" method="POST">
								<div class="form-group">
									<label for="carModel-{{ car.id }}">Modèle</label>
									<input type="text" id="carModel-{{ car.id }}" name="carModel" value="{{ car.carModel }}" required>
								</div>
								<div class="form-group">
									<label for="registration-{{ car.id }}">Immatriculation</label>
									<input type="text" id="registration-{{ car.id }}" name="registration" value="{{ car.registration }}" required>
								</div>
								<div class="form-group">
									<label for="transmission-{{ car.id }}">Transmission</label>
									<select id="transmission-{{ car.id }}" name="transmission">
										<option value="MANUELLE" {% if car.transmission == 'MANUELLE' %} selected {% endif %}>Manuelle</option>
										<option value="AUTOMATIQUE" {% if car.transmission == 'AUTOMATIQUE' %} selected {% endif %}>Automatique</option>
									</select>
								</div>
								<div class="form-group">
									<label for="employee-{{ car.id }}">Employé (optionnel)</label>
									<select id="employee-{{ car.id }}" name="employeeId">
										<option value="">--Non attribué--</option>
										{% for emp in employees %}
											{% set alreadyAssigned = false %}
											{% for otherCar in cars %}
												{% if otherCar.employeeId == emp.id and otherCar.id != car.id %}
													{% set alreadyAssigned = true %}
												{% endif %}
											{% endfor %}
											{% if not alreadyAssigned or emp.id == car.employeeId %}
												<option value="{{ emp.id }}" {% if car.employeeId == emp.id %} selected {% endif %}>
													{{ emp.firstName }}
													{{ emp.lastName | upper }}
												</option>
											{% endif %}
										{% endfor %}
									</select>
								</div>
								<button type="submit" class="submit-btn">Sauvegarder</button>
							</form>

						</div>
					{% endfor %}
				{% else %}
					<p>Aucune voiture trouvée.</p>
				{% endif %}
			</div>

		</main>
	</div>

	<script src="/assets/js/deployCarForm.js"></script>
    <script src="/assets/js/fleetSearch.js"></script>
{% endblock %}
