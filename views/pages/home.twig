{% extends "../layouts/base.twig" %}

{% block style %}
	<link rel="stylesheet" href="/assets/css/home.css">
	<link rel="stylesheet" href="/assets/css/dashboard.css">
{% endblock %}

{% block title %}
	<title>{{ title }}</title>
{% endblock %}

{% block main %}
	<div class="page">
		{% include "../partials/sidebar.twig" %}

		<main>
			<h2>Derniers ajouts</h2>

			<div class="dashboard-cards">

				{% if lastEmployee %}
					<div class="employee-card">

						<div class="employee-avatar">
							{% if lastEmployee.gender == "HOMME"%}
								<img src="/assets/img/malePP.webp" alt="Avatar">
							{% elseif lastEmployee.gender == "FEMME" %}
								<img src="/assets/img/femalePP.webp" alt="Avatar">
							{% else %}
								<img src="/assets/img/undefinedPP.webp" alt="Avatar">
							{% endif %}
						</div>

						<div class="employee-info">
							<h3>{{ lastEmployee.lastName | upper }}
								{{ lastEmployee.firstName }}</h3>
							<p>
								<strong>Age :</strong>
								{{ lastEmployee.age ? lastEmployee.age : "Non renseigné" }}</p>
							<p>
								<strong>Mail :</strong>
								{{ lastEmployee.mail }}</p>
						</div>
					</div>

				{% endif %}

				{% if lastCar %}
					<div class="car-card" data-assigned="{{ lastCar.employee ? 'true' : 'false' }}">

						<div class="car-info">
							<div class="car-plate">
								<img class="plate-flag" src="/assets/img/plaque-left.png" alt="France">
								<span class="plate-number">{{ lastCar.registration }}</span>
								<img class="plate-dept" src="/assets/img/plaque-right.png" alt="83">
							</div>
							<h3>{{ lastCar.carModel }}</h3>
							<p>
								<strong>Transmission:</strong>
								{{ lastCar.transmission }}</p>
							<p>
								<strong>Employé:</strong>
								{{ lastCar.employee ? lastCar.employee.firstName ~ ' ' ~ lastCar.employee.lastName | upper : 'Non attribué' }}
							</p>
						</div>
					</div>
				{% endif %}

			</div>

			<h2>Vue d'ensemble</h2>
			<div class="charts">

				<div class="card">
					<div class="card-header">Employés</div>
					<div class="card-body">
						<canvas id="employeesChart"></canvas>
					</div>
				</div>
				<div class="card">
					<div class="card-header">Voitures</div>
					<div class="card-body">
						<canvas id="carsChart"></canvas>
					</div>
				</div>
			</div>

		</main>
	</div>

	<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
	<script>
		document.addEventListener("DOMContentLoaded", function () {
const employeesChartEl = document.getElementById('employeesChart');
const carsChartEl = document.getElementById('carsChart');

if (employeesChartEl) {
new Chart(employeesChartEl, {
type: 'pie',
data: {
labels: [
'Avec voiture', 'Sans voiture'
],
datasets: [
{
data: [
{{ employeesWithCar }}, {{ employeesWithoutCar }}
],
backgroundColor: ['#4CAF50', '#D0363B']
}
]
},
options: {
responsive: true,
plugins: {
legend: {
position: 'bottom'
}
}
}
});
}

if (carsChartEl) {
new Chart(carsChartEl, {
type: 'pie',
data: {
labels: [
'Assignées', 'Non assignées'
],
datasets: [
{
data: [
{{ assignedCars }}, {{ unassignedCars }}
],
backgroundColor: ['#4CAF50', '#D0363B']
}
]
},
options: {
responsive: true,
plugins: {
legend: {
position: 'bottom'
}
}
}
});
}
});
	</script>
{% endblock %}
