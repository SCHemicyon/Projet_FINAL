{% extends "../layouts/base.twig" %}

{% block style %}
	<link rel="stylesheet" href="/assets/css/home.css">
	<link rel="stylesheet" href="/assets/css/employee.css">
{% endblock %}
{% block title %}
	<title>{{title}}</title>
{% endblock %}
{% block main %}
	<div class="page">
		{% include "../partials/sidebar.twig" %}

		<main>
			{% include "../partials/searchbar.twig" %}

			<!-- Bouton pour déployer le formulaire -->
			<div class="add-employee-btn">
				<button id="toggle-form">➕ Ajouter un employé</button>
			</div>

			<!-- Formulaire rétractable -->
			<form id="employee-form" action="/employees/add" method="post">
				<div class="form-group">
					<label for="lastName">Nom</label>
					<input type="text" name="lastName" id="lastName" required>
				</div>
				<div class="form-group">
					<label for="firstName">Prénom</label>
					<input type="text" name="firstName" id="firstName" required>
				</div>
				<div class="form-group">
					<label for="mail">Mail</label>
					<input type="email" name="mail" id="mail" required>
				</div>
				<div class="form-group">
					<label for="password">Mot de passe</label>
					<input type="password" name="password" id="password" required>
				</div>
				<div class="form-group">
					<label for="age">Age (optionnel)</label>
					<input type="number" name="age" id="age">
				</div>
				<div class="form-group">
					<label for="gender">Genre (optionnel)</label>
					<select name="gender" id="gender">
						<option value="">--Choisir--</option>
						<option value="HOMME">Homme</option>
						<option value="FEMME">Femme</option>
						<option value="AUTRE">Autre</option>
					</select>
				</div>
				<button type="submit" class="submit-btn">Ajouter</button>
			</form>

			{# employés #}
			<div class="employees-container">
				{% if employees.length > 0 %}
					{% for employee in employees %}
						<div class="employee-card">

							<div class="employee-avatar">
								{% if employee.gender == "HOMME"%}
									<img src="/assets/img/malePP.webp" alt="Avatar">
								{% elseif employee.gender == "FEMME" %}
									<img src="/assets/img/femalePP.webp" alt="Avatar">
								{% else %}
									<img src="/assets/img/undefinedPP.webp" alt="Avatar">
								{% endif %}
							</div>

							<div class="employee-info">
								<h3>{{ employee.lastName | upper }}
									{{ employee.firstName }}</h3>
								<p>
									<strong>Age :</strong>
									{{ employee.age ? employee.age : "Non renseigné" }}</p>
								<p>
									<strong>Mail :</strong>
									{{ employee.mail }}</p>
							</div>

							<div class="employee-actions">
								<button type="button" class="edit-btn" data-id="{{ employee.id }}">
									✏ Modifier
								</button>

								<form action="/employees/delete/{{ employee.id }}" method="POST" style="display:inline;">
									<button type="submit" class="delete-btn">
										🗑 Supprimer
									</button>
								</form>
							</div>

							<!-- Formulaire de modification rétractable -->
							<form class="employee-edit-form" action="/employees/edit/{{ employee.id }}" method="POST" style="display:none;">
								<div class="form-group">
									<label for="firstName-{{ employee.id }}">Prénom</label>
									<input type="text" id="firstName-{{ employee.id }}" name="firstName" value="{{ employee.firstName }}" required>
								</div>
								<div class="form-group">
									<label for="lastName-{{ employee.id }}">Nom</label>
									<input type="text" id="lastName-{{ employee.id }}" name="lastName" value="{{ employee.lastName }}" required>
								</div>
								<div class="form-group">
									<label for="mail-{{ employee.id }}">Mail</label>
									<input type="email" id="mail-{{ employee.id }}" name="mail" value="{{ employee.mail }}" required>
								</div>
								<div class="form-group">
									<label for="password-{{ employee.id }}">Mot de passe</label>
									<input type="password" id="password-{{ employee.id }}" name="password" placeholder="••••••">
								</div>
								<div class="form-group">
									<label for="age-{{ employee.id }}">Age</label>
									<input type="number" id="age-{{ employee.id }}" name="age" value="{{ employee.age }}">
								</div>
								<div class="form-group">
									<label for="gender-{{ employee.id }}">Genre</label>
									<select id="gender-{{ employee.id }}" name="gender">
										<option value="">--Choisir--</option>
										<option value="HOMME" {% if employee.gender == 'HOMME' %} selected {% endif %}>Homme</option>
										<option value="FEMME" {% if employee.gender == 'FEMME' %} selected {% endif %}>Femme</option>
										<option value="AUTRE" {% if employee.gender == 'AUTRE' %} selected {% endif %}>Autre</option>
									</select>
								</div>
								<button type="submit" class="submit-btn">Sauvegarder</button>
							</form>

						</div>
					{% endfor %}
				{% else %}
					<p>Aucun employé trouvé.</p>
				{% endif %}
			</div>


		</main>
	</div>
	<script src="/assets/js/deployform.js"></script>
    <script src="/assets/js/filterEmployee.js"></script>
{% endblock %}
